# API Gateway
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# JWT
JWT_SECRET=change_me
JWT_EXPIRES_IN=900
REFRESH_TOKEN_TTL_SECONDS=604800

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=smarthome
PG_USER=postgres
PG_PASSWORD=postgres
PG_SSL=false

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=SmartHomeDB
MONGO_DEVICES_COLLECTION=devices

# Redis
REDIS_URL=redis://localhost:6379
REDIS_COMMAND_STREAM=device.commands
REDIS_CACHE_OWNER_PREFIX=owner_of:
REDIS_CACHE_TTL_SECONDS=3600
