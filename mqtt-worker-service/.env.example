# =========================
# Service
# =========================
NODE_ENV=development
SERVICE_NAME=mqtt-worker-service
LOG_LEVEL=info

# =========================
# Redis
# =========================
REDIS_URL=redis://localhost:6379
REDIS_COMMAND_STREAM=device.commands
REDIS_COMMAND_GROUP=mqtt-worker-group
REDIS_COMMAND_CONSUMER=worker-1
REDIS_UPDATE_CHANNEL=device.updates
REDIS_CACHE_OWNER_PREFIX=owner_of:
REDIS_CACHE_DEVICE_PREFIX=device:
REDIS_CACHE_TTL_SECONDS=3600

# =========================
# MQTT
# =========================
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_CLIENT_ID=mqtt-worker-service
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_QOS=1
MQTT_CONTROL_TOPIC=smarthome/{owner_id}/{device_id}/control
MQTT_TELEMETRY_TOPIC=smarthome/+/+/telemetry
MQTT_ACK_TOPIC=smarthome/+/+/ack
MQTT_STATUS_TOPIC=smarthome/+/+/status

# =========================
# PostgreSQL
# =========================
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=smarthome
PG_USER=postgres
PG_PASSWORD=postgres
PG_SSL=false

# =========================
# MongoDB
# =========================
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=SmartHomeDB
MONGO_DEVICES_COLLECTION=devices
MONGO_TELEMETRY_COLLECTION=telemetry_logs

# =========================
# Worker Behavior
# =========================
COMMAND_TIMEOUT_SECONDS=15
COMMAND_RETRY_LIMIT=2
HEARTBEAT_INTERVAL_SECONDS=30
TELEMETRY_DEDUPE_TTL_SECONDS=10

